# Datenbank
DATABASE_URL=postgres://topograph:changeme@localhost:5432/topograph
DB_PASSWORD=changeme

# Auth (openssl rand -base64 32)
NEXTAUTH_URL=https://topograph.example.com
NEXTAUTH_SECRET=dein-geheimer-schluessel

# App-Version (wird automatisch gesetzt beim Docker-Build)
APP_VERSION=1.0.0

# LDAP / Active Directory (optional — leer lassen wenn nicht benötigt)
LDAP_URL=ldap://dc.example.com
LDAP_DOMAIN=example.com
LDAP_BASE_DN=DC=example,DC=com
LDAP_GROUP_DN=CN=Topograph,OU=Gruppen,DC=example,DC=com
# Service-Account für rekursive Gruppenprüfung (optional)
LDAP_BIND_DN=CN=svc-topograph,OU=Dienste,DC=example,DC=com
LDAP_BIND_PASSWORD=sicheres-passwort

# Branding (optional)
APP_NAME=Topograph
PRIMARY_COLOR=#6366f1
LOGO_URL=https://example.com/logo.png

# Docker-Update (für Admin-Update-Funktion)
UPDATE_REPO=your-org/topograph
DOCKER_IMAGE=ghcr.io/your-org/topograph:latest
COMPOSE_DIR=/opt/topograph
