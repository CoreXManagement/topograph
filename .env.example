# ── Pflichtfelder (nur diese 3 sind wirklich nötig) ──────────────────────────

# Datenbank-Passwort (für docker-compose intern)
DB_PASSWORD=sicheres-datenbankpasswort

# Öffentliche URL der App
NEXTAUTH_URL=https://topograph.example.com

# Zufalls-Secret: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Optionale Felder ──────────────────────────────────────────────────────────

# Port-Bindung für direktes Deployment (ohne Reverse Proxy)
# APP_PORT=3000

# Branding (alternativ alles in Admin → Einstellungen konfigurierbar)
# APP_NAME=Topograph
# PRIMARY_COLOR=#6366f1
# LOGO_URL=

# ── Intern (werden vom CI/Dockerfile gesetzt, nicht anfassen) ─────────────────
# APP_VERSION wird beim Docker-Build automatisch gesetzt
# UPDATE_REPO, DOCKER_IMAGE, COMPOSE_DIR werden in docker-compose.yml gesetzt
